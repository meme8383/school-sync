# Notion
NOTION_API_KEY_FILE=/path/to/notion/api_key
# NOTION_API_KEY=ntn_...                          # or set directly
NOTION_DATABASE_ID=your-database-id

# Brightspace calendar (imported into Google Calendar)
BRIGHTSPACE_CALENDAR_ID=your-calendar-id@import.calendar.google.com
SYNC_DAYS_AHEAD=180

# Course mappings (JSON array, required)
COURSES_JSON=[{"course_label":"COURSE 101","brightspace_ou":"123456","gradescope_id":"789012"}]

# OpenClaw notifications (reads token/port from ~/.openclaw/openclaw.json by default)
OPENCLAW_ENABLED=1
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_HOOKS_TOKEN=your-hooks-token
OPENCLAW_TELEGRAM_TO=your-telegram-user-id

# Polling interval for --watch mode (minutes)
POLL_INTERVAL_MINUTES=30

# Timezone
TZ=America/Indiana/Indianapolis
